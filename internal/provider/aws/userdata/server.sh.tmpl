#!/bin/sh
# k3s server bootstrap. Templated by Bonsai before being passed as EC2 user-data.
set -eu

NAME="{{.Name}}"
ENV="{{.Env}}"
REGION="{{.Region}}"

# Install AWS CLI if not present (AL2023 ships it; Alpine may not).
command -v aws >/dev/null 2>&1 || {
  if command -v dnf >/dev/null; then dnf install -y awscli >/dev/null
  elif command -v apk >/dev/null; then apk add --no-cache aws-cli >/dev/null
  fi
}

# k3s server. Phase 1: embedded SQLite (single-node).
# Phase 3 swaps in --cluster-init for embedded etcd HA.
curl -sfL https://get.k3s.io | sh -s - server \
  --write-kubeconfig-mode=0644 \
  --tls-san="$(curl -s http://169.254.169.254/latest/meta-data/public-hostname)" \
  --disable=traefik

# Publish the cluster join token so workers can find it.
TOKEN="$(cat /var/lib/rancher/k3s/server/node-token)"
aws ssm put-parameter \
  --region "$REGION" \
  --name "/bonsai/${NAME}/${ENV}/token" \
  --type SecureString \
  --value "$TOKEN" \
  --overwrite

# Publish the cluster API endpoint (public hostname).
ENDPOINT="https://$(curl -s http://169.254.169.254/latest/meta-data/public-hostname):6443"
aws ssm put-parameter \
  --region "$REGION" \
  --name "/bonsai/${NAME}/${ENV}/cluster_endpoint" \
  --type String \
  --value "$ENDPOINT" \
  --overwrite

# Publish kubeconfig with the API server rewritten to the public hostname so
# operators can connect from outside the VPC.
KUBECFG="$(sed "s|127.0.0.1|$(curl -s http://169.254.169.254/latest/meta-data/public-hostname)|g" /etc/rancher/k3s/k3s.yaml)"
aws ssm put-parameter \
  --region "$REGION" \
  --name "/bonsai/${NAME}/${ENV}/kubeconfig" \
  --type SecureString \
  --value "$KUBECFG" \
  --overwrite
