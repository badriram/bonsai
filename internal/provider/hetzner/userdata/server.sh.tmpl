#cloud-config
# k3s server cloud-init for Hetzner. Templated by Bonsai.
#
# cloud-init's ssh_keys: module runs in the local init stage, BEFORE sshd
# starts. That means sshd boots with the Bonsai-installed host key, so
# operator's first SSH connect can pin against it (ssh.FixedHostKey) and an
# on-path attacker can't impersonate the server with their own host key.

ssh_keys:
  ed25519_private: |
{{.HostKeyPrivateIndented}}
  ed25519_public: '{{.HostKeyPublic}}'

runcmd:
  - |
    set -eu
    # Pin a known-good k3s. Bonsai pulls kubeconfig + token via SSH after this completes.
    curl -sfL https://get.k3s.io | \
      INSTALL_K3S_VERSION="{{.K3sVersion}}" \
      sh -s - server \
      --write-kubeconfig-mode=0644 \
      --tls-san="{{.ControlIP}}" \
      --disable=traefik

    # Marker so Bonsai's SSH poll knows server.sh finished, not just that sshd is up.
    touch /var/lib/bonsai-server-ready
